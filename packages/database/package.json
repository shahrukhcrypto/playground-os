{
  "name": "@playground/database",
  "version": "0.1.0",
  "private": true,
  "description": "Shared database client, schema, and migrations for Playground OS",
  "license": "MIT",
  "type": "module",
  "prettier": "@playground/config/prettier",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js"
    }
  },
  "files": ["dist", "drizzle"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/run.ts"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "postgres": "^3.4.7",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@playground/config": "workspace:*",
    "@types/node": "^22.15.29",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
